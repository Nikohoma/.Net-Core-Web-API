@model List<ConsumingAPI.Models.Product>

<h2>Products</h2>

<table border="1">
    <tr>
        <th>Id</th>
        <th>Title</th>
        <th>Price</th>
    </tr>

    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Id</td>
            <td>@p.Title</td>
            <td>@p.Price</td>
        </tr>
    }

</table>