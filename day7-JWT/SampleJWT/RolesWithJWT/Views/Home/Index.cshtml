@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">
    <h2>Welcome, @User.Identity?.Name!</h2>
    <p>You are logged in as: <strong>@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</strong></p>

    <div class="mt-3">
        <a href="/Home/AdminPanel" class="btn btn-warning">Go to Admin Panel</a>  <!--Redirect to AdminPanel() in HomeController-->
        <a href="/Home/UserPanel" class="btn btn-warning">Go to User Panel</a>
        <a href="/Login/Logout" class="btn btn-danger ms-2">Logout</a>
    </div>
</div>